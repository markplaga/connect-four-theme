{
  "name": "connect-four-theme",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx netlify dev",
    "deploy": "npx netlify deploy --prod",
    "check:js": "node --check game-core.js && node --check game-online.js",
    "check:types": "tsc --noEmit",
