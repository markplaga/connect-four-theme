  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@netlify/blobs": "10.7.9",
    "@netlify/functions": "5.3.0"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
